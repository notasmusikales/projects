<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_solicitud" model="ir.actions.act_window">
        <field name="name">Solicitudes</field>
        <field name="res_model">gestion.solicitud</field>
        <field name="view_mode">tree,form,kanban</field>
    </record>

    <record id="action_categoria" model="ir.actions.act_window">
        <field name="name">Categorías</field>
        <field name="res_model">gestion.categoria</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_prioridad" model="ir.actions.act_window">
        <field name="name">Prioridades</field>
        <field name="res_model">gestion.prioridad</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_gestion_solicitudes_root"
              name="Gestión de Solicitudes"
              web_icon="gestion_solicitudes,static/description/icon.png"
              sequence="10"/>

    <menuitem id="menu_solicitudes"
              name="Solicitudes"
              parent="menu_gestion_solicitudes_root"
              action="action_solicitud"
              sequence="1"/>

    <menuitem id="menu_configuracion"
              name="Configuración"
              parent="menu_gestion_solicitudes_root"
              sequence="100"/>

    <menuitem id="menu_categorias"
              name="Categorías"
              parent="menu_configuracion"
              action="action_categoria"
              sequence="1"/>

    <menuitem id="menu_prioridades"
              name="Prioridades"
              parent="menu_configuracion"
              action="action_prioridad"
              sequence="2"/>
</odoo>