<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <kanban class="o_kanban_small_column" default_group_by="state">
        <templates>
            <t t-name="kanban-box">
                <div class="oe_kanban_global_click">
                    <div class="o_kanban_record_top">
                        <div class="o_kanban_record_head">
                            <strong class="o_kanban_record_title"><field name="name"/></strong>
                        </div>
                        <div class="o_kanban_tags">
                            <span class="badge bg-secondary"><field name="categoria_id"/></span>
                            <span class="badge bg-info"><field name="prioridad_id"/></span>
                        </div>
                    </div>
                    <div class="o_kanban_record_body">
                        <div><strong>Solicitante:</strong> <field name="partner_id"/></div>
                        <div><strong>Asignado:</strong> <field name="assigned_to"/></div>
                        <div t-if="record.date_deadline.raw_value"><strong>Fecha Límite:</strong> <field name="date_deadline"/></div>
                    </div>
                    <div class="o_kanban_record_bottom">
                        <div class="oe_kanban_bottom_left">
                            <field name="state"/>
                        </div>
                    </div>
                </div>
            </t>
        </templates>
    </kanban>
</odoo>